rules_version = '2';

/**
 * ==============================================================================
 * FinBench365 — Production Cloud Firestore Security Rules (Sprint 3)
 * ==============================================================================
 * Enforces Institutional Role-Based Access Control (RBAC) and data boundaries:
 * - Guests: No access to sensitive candidate records or proprietary question banks.
 * - Students: Access only to their own profile, attempts, subscriptions, and purchased/sample course content.
 * - Admins: Manage educational catalog (`courses`, `mockTests`, `questions`, `notes`).
 * - Super Admin: Full platform access across all collections.
 * - Payments: Write-restricted to backend Cloud Functions / Admin SDK only.
 * - Analytics: Read-only for Admins; Write-restricted to backend only.
 * - Activity Logs: Append-only for authenticated actions; immutable thereafter.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================================================
    // Core Helper & Role Verification Functions
    // ==========================================================================

    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role in ['ADMIN', 'SUPER_ADMIN'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         getUserData().role in ['ADMIN', 'SUPER_ADMIN'])
      );
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'SUPER_ADMIN' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         getUserData().role == 'SUPER_ADMIN')
      );
    }

    function hasPurchasedAccess(trackId, courseId) {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (
          trackId in getUserData().activeTrackIds ||
          courseId in getUserData().activeTrackIds ||
          getUserData().subscriptionStatus == 'ACTIVE'
        )
      );
    }

    // ==========================================================================
    // 1. Candidate Profiles (`users`)
    // ==========================================================================
    match /users/{userId} {
      // Students can read their own profile; Admins can read all profiles
      allow read: if isOwner(userId) || isAdmin();
      
      // Candidate creation allowed on initial registration for own UID
      allow create: if isOwner(userId) && request.resource.data.role == 'STUDENT';
      
      // Students can update safe profile fields (e.g. displayName, photoURL, preferences)
      // They CANNOT self-elevate role or tamper with activeTrackIds / subscriptionStatus directly
      allow update: if isOwner(userId) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.activeTrackIds == resource.data.activeTrackIds &&
        request.resource.data.subscriptionStatus == resource.data.subscriptionStatus;

      // Only Super Admin can delete or modify administrative roles
      allow delete, write: if isSuperAdmin();
    }

    // ==========================================================================
    // 2. Educational Curriculum & Catalog (`courses`, `courseCategories`)
    // ==========================================================================
    match /courses/{courseId} {
      // Public read allowed for active course catalog displays & checkout preview
      allow read: if resource.data.status == 'ACTIVE' || isAdmin();
      allow write: if isAdmin();
    }

    match /courseCategories/{categoryId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // ==========================================================================
    // 3. Proprietary Study Materials & Examination Banks (`notes`, `mockTests`, `questions`)
    // ==========================================================================
    match /notes/{noteId} {
      allow read: if isAdmin() || (
        isAuthenticated() && (
          hasPurchasedAccess(resource.data.trackId, resource.data.courseId)
        )
      );
      allow write: if isAdmin();
    }

    match /mockTests/{mockTestId} {
      allow read: if isAdmin() || (
        isAuthenticated() && (
          resource.data.isFreeSample == true ||
          hasPurchasedAccess(resource.data.trackId, resource.data.courseId)
        )
      );
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if isAdmin() || (
        isAuthenticated() && (
          hasPurchasedAccess(resource.data.trackId, resource.data.courseId) ||
          get(/databases/$(database)/documents/mockTests/$(resource.data.mockTestId)).data.isFreeSample == true
        )
      );
      allow write: if isAdmin();
    }

    // ==========================================================================
    // 4. Examination Attempts & Diagnostic Responses (`attempts`)
    // ==========================================================================
    match /attempts/{attemptId} {
      // Candidates can read their own evaluation history
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // Candidates can initialize attempts for themselves
      allow create: if isOwner(request.resource.data.userId) &&
        request.resource.data.attemptStatus == 'IN_PROGRESS';
        
      // Candidates can update question responses during active attempt execution
      allow update: if isOwner(resource.data.userId) &&
        resource.data.attemptStatus == 'IN_PROGRESS';
        
      allow delete: if isSuperAdmin();
    }

    // ==========================================================================
    // 5. Subscription Licenses (`subscriptions`)
    // ==========================================================================
    match /subscriptions/{subscriptionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // Backend / Admin SDK handles verified creation; candidates can only request cancellation
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isOwner(resource.data.userId) &&
        request.resource.data.subscriptionState == 'CANCELLED' &&
        request.resource.data.userId == resource.data.userId
      );
      allow delete: if isSuperAdmin();
    }

    // ==========================================================================
    // 6. Immutable Financial Transactions (`payments`)
    // ==========================================================================
    match /payments/{paymentId} {
      // Students can view their transaction receipts
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // Client CANNOT create, edit, or verify payments. Exclusively handled by Cloud Functions / Admin SDK
      allow write: if false;
    }

    // ==========================================================================
    // 7. Promotional Vouchers & Institutional Tier Coupons (`couponCodes`)
    // ==========================================================================
    match /couponCodes/{couponId} {
      // Authenticated candidates can read active coupons for checkout validation
      allow read: if isAuthenticated() && resource.data.isActive == true;
      allow write: if isAdmin();
    }

    // ==========================================================================
    // 8. Institutional Administrators (`admins`, `roles`)
    // ==========================================================================
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    match /roles/{roleId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    // ==========================================================================
    // 9. System Alerts & Notifications (`notifications`)
    // ==========================================================================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || resource.data.userId == 'ALL'
      );
      // Candidates can mark notifications as read (`isRead: true`)
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || resource.data.userId == 'ALL'
      ) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt', 'updatedAt']);
      allow create, delete: if isAdmin();
    }

    // ==========================================================================
    // 10. Institutional Analytics & Telemetry (`analytics`)
    // ==========================================================================
    match /analytics/{snapshotId} {
      // Read-only for Admins; Write-only through backend Cloud Functions
      allow read: if isAdmin();
      allow write: if false;
    }

    // ==========================================================================
    // 11. Immutable Compliance Audit Logs (`activityLogs`)
    // ==========================================================================
    match /activityLogs/{logId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      // Append-only: authenticated users can log actions for their own UID
      allow create: if isOwner(request.resource.data.userId);
      // Updates and deletions strictly forbidden to preserve audit integrity
      allow update, delete: if false;
    }
  }
}
